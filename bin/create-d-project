#!/usr/bin/env bash

# create-d-project
# Deterministic project generator for The Learning Box (TLB)
# Usage: create-d-project <project-name> <parent-path>

set -e

PROJECT_NAME="$1"
PARENT_PATH="$2"

# Validate args
if [ -z "$PROJECT_NAME" ] || [ -z "$PARENT_PATH" ]; then
    echo "ERROR: Usage: create-d-project <project-name> <parent-path>"
    exit 1
fi

# Validate parent path exists
if [ ! -d "$PARENT_PATH" ]; then
    echo "ERROR: Target parent path does not exist: $PARENT_PATH"
    exit 1
fi

TARGET="$PARENT_PATH/$PROJECT_NAME"

# Prevent overwriting existing project
if [ -d "$TARGET" ]; then
    echo "ERROR: Target project already exists: $TARGET"
    exit 1
fi

# Create directory structure
mkdir -p "$TARGET/src"
mkdir -p "$TARGET/.vscode"

# Create dub.json
cat > "$TARGET/dub.json" <<EOF
{
    "name": "$PROJECT_NAME",
    "description": "A D project generated by The Learning Box",
    "authors": ["Benny"],
    "dependencies": {},
    "targetType": "executable",
    "sourcePaths": ["src"]
}
EOF

# Create tlb.json (canonical manifest)
cat > "$TARGET/tlb.json" <<EOF
{
    "project": "$PROJECT_NAME",
    "version": 1,
    "type": "d-project",
    "createdBy": "create-d-project",
    "createdFor": "The Learning Box",
    "notes": "This file replaces legacy rca.json"
}
EOF

# Create JOURNAL.md
cat > "$TARGET/JOURNAL.md" <<EOF
# JOURNAL — $PROJECT_NAME

This journal is for recording discoveries, experiments, and observations.
EOF

# Create main.d
cat > "$TARGET/src/main.d" <<EOF
import std.stdio;

void main()
{
    writeln("Hello from $PROJECT_NAME");
}
EOF

# Create VS Code launch.json
cat > "$TARGET/.vscode/launch.json" <<EOF
{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "D Debug",
            "type": "lldb",
            "request": "launch",
            "program": "\${workspaceFolder}/main",
            "args": [],
            "cwd": "\${workspaceFolder}",
            "preLaunchTask": "build-d"
        }
    ]
}
EOF

# Create VS Code tasks.json
cat > "$TARGET/.vscode/tasks.json" <<EOF
{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-d",
            "type": "shell",
            "command": "dmd -g -debug src/main.d -of=main",
            "group": "build"
        }
    ]
}
EOF

echo "Project created successfully: $TARGET"
